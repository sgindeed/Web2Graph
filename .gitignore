# --- SENSITIVE DATA (CRITICAL) ---
# Prevents your Groq API Key and other secrets from leaking
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- PYTHON / BACKEND (Render) ---
# Python bytecode and cache[cite: 1, 4]
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Environments
venv/
.venv/
env/
bin/
lib/

# Local Database & Storage[cite: 4, 5]
# Prevents committing local ChromaDB vector stores
chroma_db/
*.db
*.sqlite3

# --- JAVASCRIPT / FRONTEND (Netlify) ---
# Dependencies
node_modules/
.pnpm-store/

# Production builds[cite: 6]
dist/
build/
.next/
out/

# Logs and system files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache

# --- OS SPECIFIC ---
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
desktop.ini